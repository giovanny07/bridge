{
    "name": "imagunet/bridge",
    "description": "GLPI plugin to scan and migrate ITSM/ITAM data from external platforms.",
    "version": "1.1.1",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "GlpiPlugin\\Bridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlpiPlugin\\Bridge\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test":     "phpunit --bootstrap tests/bootstrap.php --testdox tests/units/",
        "test:api": "phpunit --bootstrap tests/bootstrap.php --testdox --group api tests/api/"
    }
}
